# Local testing only. Do not place real production secrets in this file.

# Select network config from `<repo_root>/config/<AZTEC_ENV>.json`.
# - local: `local-network`
# - public testnet: `testnet`
AZTEC_ENV=local-network

# Guardian account secrets
SECRET=replace_me
SIGNING_KEY=replace_me
SALT=replace_me

# Used by later slices of the implementation plan.
CERTIFICATE_REGISTRY_ADDRESS=replace_me
CERTIFICATE_REGISTRY_DEPLOYMENT_SALT=replace_me
CERTIFICATE_REGISTRY_ADMIN_ADDRESS=replace_me
CERTIFICATE_REGISTRY_DEPLOYER_ADDRESS=replace_me
