{
  "name": "@galactica-net/guardian-aztec-connect",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "guardian-aztec-connect": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.config.json --testPathPattern=test/unit/",
    "test:integration": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.config.json --testPathPattern=test/integration/",
    "cli": "NODE_NO_WARNINGS=1 node --loader ts-node/esm src/cli.ts",
    "account:status": "yarn cli -- account status",
    "account:deploy": "yarn cli -- account deploy"
  },
  "dependencies": {
    "@aztec/aztec.js": "4.0.0-devnet.2-patch.1",
    "@aztec/constants": "4.0.0-devnet.2-patch.1",
    "@aztec/noir-contracts.js": "4.0.0-devnet.2-patch.1",
    "@aztec/stdlib": "4.0.0-devnet.2-patch.1",
    "@aztec/wallets": "4.0.0-devnet.2-patch.1",
    "dotenv": "^17.2.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.15.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
