# Sumsub (required for API and webhook)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET_KEY=

# Aztec / guardian-aztec-connect (required for issuance)
AZTEC_ENV=local-network

# Guardian account secrets
SECRET=
SIGNING_KEY=
SALT=

# Certificate registry
CERTIFICATE_REGISTRY_ADDRESS=
CERTIFICATE_REGISTRY_ADMIN_ADDRESS=
CERTIFICATE_REGISTRY_DEPLOYMENT_SALT=
CERTIFICATE_REGISTRY_DEPLOYER_ADDRESS=

# Server (optional)
PORT=3004

# CORS: comma-separated allowed origins (default: http://localhost:5173)
CORS_ALLOW_ORIGINS=http://localhost:5173
