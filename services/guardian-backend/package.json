{
  "name": "@galactica-net/guardian-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/Galactica-corp/aztec-zkkyc.git",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.config.json --testPathPattern=test/unit/",
    "test:integration": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.config.json --testPathPattern=test/integration/",
    "dev": "NODE_NO_WARNINGS=1 node --loader ts-node/esm src/server.ts",
    "start": "node dist/server.js",
    "cli": "NODE_NO_WARNINGS=1 node --loader ts-node/esm src/cli.ts"
  },
  "dependencies": {
    "@galactica-net/guardian-aztec-connect": "1.0.0",
    "dotenv": "^17.2.2",
    "i18n-iso-countries": "^7.14.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.15.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
